# ─────────────────────────────────────────────────────────────
# Образец переменных окружения для Agent Bot.
# Скопируйте в .env и заполните значениями:  cp .env.example .env
# Файл .env в репозиторий НЕ коммитится (см. .gitignore).
# На сервере значения подхватываются через systemd EnvironmentFile.
# ─────────────────────────────────────────────────────────────

# ── Обязательные (системные) ──────────────────────────────────
# Токен Telegram-бота от @BotFather
BOT_TOKEN=
# Ваш Telegram user id (владелец бота)
OWNER_ID=
# Домашний каталог агента на сервере (по умолчанию /home/agent)
AGENT_HOME=

# ── Поиск по памяти / эмбеддинги ──────────────────────────────
# Ключ Voyage AI для построения эмбеддингов
VOYAGE_API_KEY=

# ── Опциональные сервисы (подключаются по желанию) ────────────
# Deepgram — распознавание голосовых сообщений
DEEPGRAM_API_KEY=
# OpenRouter — доступ к дополнительным моделям
OPENROUTER_API_KEY=
# OpenAI — TTS, генерация картинок, GPT-модели
OPENAI_API_KEY=
# Notion — чтение/запись базы знаний
NOTION_API_KEY=
# GitHub — push/pull, создание репозиториев и PR
GITHUB_TOKEN=
# Vercel — деплой сайтов
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
# Stripe — приём платежей
STRIPE_API_KEY=
